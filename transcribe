#!/bin/bash
# Transcribe audio files to text using OpenAI Whisper API

set -e

# Check if required arguments are provided
if [ $# -lt 2 ]; then
    echo "Usage: transcribe <audio_file> <output_file>"
    echo "Example: transcribe audio.m4a convo.txt"
    exit 1
fi

AUDIO_FILE="$1"
OUTPUT_FILE="$2"
TEMP_FILE=""
TEMP_CHUNKS=()
MAX_SIZE_MB=24

# Check if audio file exists
if [ ! -f "$AUDIO_FILE" ]; then
    echo "Error: Audio file '$AUDIO_FILE' not found."
    exit 1
fi

# Check if OPENAI_API_KEY is set
if [ -z "$OPENAI_API_KEY" ]; then
    echo "Error: OPENAI_API_KEY environment variable is not set."
    echo "Please set it with: export OPENAI_API_KEY='your-api-key'"
    exit 1
fi

# Check if required tools are installed
if ! command -v ffmpeg &> /dev/null; then
    echo "Error: ffmpeg is not installed."
    echo "Please install it with: sudo apt install ffmpeg"
    exit 1
fi

if ! command -v jq &> /dev/null; then
    echo "Error: jq is not installed."
    echo "Please install it with: sudo apt install jq"
    exit 1
fi

# Cleanup function
cleanup() {
    if [ -n "$TEMP_FILE" ] && [ -f "$TEMP_FILE" ]; then
        rm -f "$TEMP_FILE"
    fi
    for chunk in "${TEMP_CHUNKS[@]}"; do
        if [ -f "$chunk" ]; then
            rm -f "$chunk"
        fi
    done
}
trap cleanup EXIT

# Convert to mp3 if not already mp3
FILE_EXT="${AUDIO_FILE##*.}"
if [ "${FILE_EXT,,}" != "mp3" ]; then
    echo "Converting '$AUDIO_FILE' to mp3..."
    TEMP_FILE=$(mktemp --suffix=.mp3)
    ffmpeg -i "$AUDIO_FILE" -acodec libmp3lame -ab 192k "$TEMP_FILE" -y -loglevel warning
    AUDIO_FILE="$TEMP_FILE"
    echo "Conversion complete."
    echo ""
fi

echo "Transcribing audio file..."
echo ""

# Verify the file exists before sending to API
if [ ! -f "$AUDIO_FILE" ]; then
    echo "Error: Audio file '$AUDIO_FILE' does not exist after conversion."
    exit 1
fi

echo "Using file: $AUDIO_FILE"
FILE_SIZE_MB=$(du -m "$AUDIO_FILE" | cut -f1)
echo "File size: $(du -h "$AUDIO_FILE" | cut -f1) (${FILE_SIZE_MB}MB)"
echo ""

# Check if file needs to be split
if [ "$FILE_SIZE_MB" -gt "$MAX_SIZE_MB" ]; then
    echo "File exceeds ${MAX_SIZE_MB}MB limit. Splitting into chunks..."
    echo ""

    # Get duration in seconds
    echo "Analyzing audio duration..."
    DURATION=$(ffmpeg -i "$AUDIO_FILE" 2>&1 | grep "Duration" | awk '{print $2}' | tr -d , | awk -F: '{print ($1 * 3600) + ($2 * 60) + $3}')
    DURATION_INT=${DURATION%.*}

    if [ -z "$DURATION_INT" ] || [ "$DURATION_INT" -eq 0 ]; then
        echo "Error: Could not determine audio duration"
        exit 1
    fi

    # Calculate chunk duration to keep each chunk under MAX_SIZE_MB
    CHUNKS_NEEDED=$(( (FILE_SIZE_MB + MAX_SIZE_MB - 1) / MAX_SIZE_MB ))
    CHUNK_DURATION=$(( DURATION_INT / CHUNKS_NEEDED ))

    echo "Total duration: ${DURATION_INT}s, splitting into $CHUNKS_NEEDED chunks of ~${CHUNK_DURATION}s each"
    echo ""

    # Split the file
    for i in $(seq 0 $((CHUNKS_NEEDED - 1))); do
        START_TIME=$((i * CHUNK_DURATION))
        CHUNK_FILE=$(mktemp --suffix=.mp3)
        TEMP_CHUNKS+=("$CHUNK_FILE")

        echo "Creating chunk $((i + 1))/$CHUNKS_NEEDED (starting at ${START_TIME}s)..."
        ffmpeg -i "$AUDIO_FILE" -ss "$START_TIME" -t "$CHUNK_DURATION" -acodec copy "$CHUNK_FILE" -y -loglevel warning
    done
    echo ""

    # Transcribe each chunk
    > "$OUTPUT_FILE"
    for i in "${!TEMP_CHUNKS[@]}"; do
        CHUNK="${TEMP_CHUNKS[$i]}"
        CHUNK_SIZE=$(du -h "$CHUNK" | cut -f1)
        echo "Transcribing chunk $((i + 1))/${#TEMP_CHUNKS[@]} (size: $CHUNK_SIZE)..."

        response=$(curl -s -w "\nHTTP_STATUS:%{http_code}" -X POST "https://api.openai.com/v1/audio/transcriptions" \
            -H "Authorization: Bearer $OPENAI_API_KEY" \
            -F "file=@$CHUNK" \
            -F "model=whisper-1" \
            -F "response_format=json")

        http_status=$(echo "$response" | grep "HTTP_STATUS:" | cut -d: -f2)
        response_body=$(echo "$response" | sed '/HTTP_STATUS:/d')

        echo "DEBUG: HTTP Status = $http_status"
        echo "DEBUG: Response body length = ${#response_body}"
        echo "DEBUG: First 500 chars of response:"
        echo "$response_body" | head -c 500
        echo ""
        echo ""

        if [ "$http_status" != "200" ]; then
            echo "Error: API request failed with status $http_status"
            echo "Full response body:"
            echo "$response_body"
            echo ""
            if echo "$response_body" | jq -e '.error' &> /dev/null; then
                echo "Error message: $(echo "$response_body" | jq -r '.error.message')"
            fi
            exit 1
        fi

        transcription=$(echo "$response_body" | jq -r '.text')

        if [ -z "$transcription" ] || [ "$transcription" = "null" ]; then
            echo "Error: Failed to extract transcription from chunk $((i + 1))"
            echo "Response: $response_body"
            exit 1
        fi

        echo "$transcription" >> "$OUTPUT_FILE"
        echo " ">> "$OUTPUT_FILE"
        echo "✓ Chunk $((i + 1))/${#TEMP_CHUNKS[@]} complete"
        echo ""
    done
else
    # File is small enough, transcribe directly
    echo "Sending to OpenAI API..."
    response=$(curl -s -w "\nHTTP_STATUS:%{http_code}" -X POST "https://api.openai.com/v1/audio/transcriptions" \
        -H "Authorization: Bearer $OPENAI_API_KEY" \
        -F "file=@$AUDIO_FILE" \
        -F "model=whisper-1" \
        -F "response_format=json")

    http_status=$(echo "$response" | grep "HTTP_STATUS:" | cut -d: -f2)
    response_body=$(echo "$response" | sed '/HTTP_STATUS:/d')

    echo "DEBUG: HTTP Status = $http_status"
    echo "DEBUG: Response body length = ${#response_body}"
    echo "DEBUG: First 500 chars of response:"
    echo "$response_body" | head -c 500
    echo ""
    echo ""

    if [ "$http_status" != "200" ]; then
        echo "Error: API request failed with status $http_status"
        echo "Full response body:"
        echo "$response_body"
        echo ""
        if echo "$response_body" | jq -e '.error' &> /dev/null; then
            echo "Error message: $(echo "$response_body" | jq -r '.error.message')"
        fi
        exit 1
    fi

    transcription=$(echo "$response_body" | jq -r '.text')

    if [ -z "$transcription" ] || [ "$transcription" = "null" ]; then
        echo "Error: Failed to extract transcription from API response."
        echo "Response: $response_body"
        exit 1
    fi

    echo "$transcription" > "$OUTPUT_FILE"
fi

echo "Transcription complete!"
echo "Output saved to: $OUTPUT_FILE"
echo ""
echo "Preview:"
echo "----------------------------------------"
head -c 200 "$OUTPUT_FILE"
if [ $(wc -c < "$OUTPUT_FILE") -gt 200 ]; then
    echo "..."
fi
echo ""
echo "----------------------------------------"
